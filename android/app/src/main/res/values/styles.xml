<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>


    <!--
      Splash.

      El `android:background` que pone Capacitor por defecto solo lo respetan
      Android 11 y anteriores. Desde Android 12 (API 31) el sistema dibuja su
      propia pantalla de arranque y quien manda es
      `windowSplashScreenBackground`: sin esa línea el splash sale BLANCO en la
      mayoría de móviles actuales, por bien puesto que esté el color en el resto
      del proyecto. Es el sitio que siempre se escapa.

      `postSplashScreenTheme` marca a qué tema saltar al terminar, para que no
      se cuele un fotograma con barra de acción antes del WebView.
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>