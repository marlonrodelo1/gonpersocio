# Copia este archivo a `.env` y rellena los valores.
# `.env` NO se versiona.

# Proyecto Supabase (el mismo que usan el panel web y la app de clientes:
# la sesión del dueño es la misma cuenta con la que entra a gonperstudio.shop).
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Clave PUBLICABLE (la que empieza por sb_publishable_ o el anon key).
# No es secreta: viaja dentro del binario de la app. La que NUNCA va aquí es
# la service_role.
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Backend Next. En desarrollo, el servidor local; en producción lo pisa
# .env.production con https://gonperstudio.shop
VITE_API_BASE=http://localhost:3000
